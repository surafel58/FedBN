diff --git a/baselines/fedbn/fedbn/utils.py b/baselines/fedbn/fedbn/utils.py
index aceace0..65b996c 100644
--- a/baselines/fedbn/fedbn/utils.py
+++ b/baselines/fedbn/fedbn/utils.py
@@ -1,12 +1,42 @@
 """fedbn: A Flower Baseline."""
 
 
-def extract_weights(net, algorithm_name):
-    """Extract model parameters as numpy arrays from state_dict."""
-    if algorithm_name == "FedAvg":
-        return [val.cpu().numpy() for _, val in net.state_dict().items()]
+def is_bn_local(name, mode):
+    """Return True if this state_dict tensor is kept LOCAL (not shared).
+
+    mode:
+      "none"/"FedAvg" -> nothing local (plain FedAvg, all tensors shared)
+      "all"/"FedBN"   -> ALL BatchNorm tensors local (FedBN baseline)
+      "affine"        -> only BN affine (weight=gamma, bias=beta) LOCAL;
+                         running_mean/var/num_batches_tracked SHARED
+                         (this is the "stats-shared" diagnostic variant)
+      "stats"         -> only BN running stats LOCAL;
+                         affine (gamma/beta) SHARED
+                         (this is the "affine-shared" diagnostic variant)
+    """
+    if mode in ("FedAvg", "none"):
+        return False
+    if mode in ("FedBN", "all"):
+        return "bn" in name
+    if "bn" not in name:
+        return False
+    is_affine = name.endswith(".weight") or name.endswith(".bias")
+    is_stat = (
+        "running_mean" in name
+        or "running_var" in name
+        or "num_batches_tracked" in name
+    )
+    if mode == "affine":
+        return is_affine
+    if mode == "stats":
+        return is_stat
+    raise ValueError(f"unknown bn-local-mode: {mode!r}")
+
+
+def extract_weights(net, mode):
+    """Return the SHARED params (numpy) = every tensor not kept local."""
     return [
         val.cpu().numpy()
         for name, val in net.state_dict().items()
-        if "bn" not in name
+        if not is_bn_local(name, mode)
     ]
