@@ -16,6 +16,29 @@ from flwr.server import (
 from flwr.server.strategy import FedAvg
 
 
+class PeriodicEvalFedAvg(FedAvg):
+    """FedAvg that only runs federated evaluation every `eval_every` rounds.
+
+    (and always on the final round). Training is unchanged; this only reduces
+    how often the (expensive) all-client evaluation is triggered.
+    """
+
+    def __init__(self, *args, eval_every=5, total_rounds=10, **kwargs):
+        super().__init__(*args, **kwargs)
+        self.eval_every = int(eval_every)
+        self.total_rounds = int(total_rounds)
+
+    def configure_evaluate(self, server_round, parameters, client_manager):
+        if (
+            server_round % self.eval_every != 0
+            and server_round != self.total_rounds
+        ):
+            return []
+        return super().configure_evaluate(
+            server_round, parameters, client_manager
+        )
+
+
